# ==============================================================================
# sDECK CONFIGURATION ENVIRONMENT VARIABLES
# Copy this file to a new file named '.env' in the same folder and customize it.
# ==============================================================================

# Port the server will run on (Default: 3000)
PORT=3000

# Overlay Social Media Handles (Display on Twitch Overlays)
# If left empty, these will fallback to 'Streamer' or default handles.
TWITCH_USERNAME=your_twitch_username
TWITTER_HANDLE=@your_twitter
INSTAGRAM_HANDLE=@your_instagram
TIKTOK_HANDLE=@your_tiktok
YOUTUBE_HANDLE=@your_youtube
